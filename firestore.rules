rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isAuthor() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'author' ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    function isOwnUser(uid) {
      return request.auth.uid == uid;
    }

    // ============================================================================
    // USERS COLLECTION - Authentication & Profile Management
    // ============================================================================
    match /users/{userId} {
      allow create: if request.auth.uid == userId && 
                      request.resource.data.role == 'user' &&
                      request.resource.data.keys().hasAll(['uid', 'role', 'createdAt']);
      allow read: if request.auth.uid == userId;
      allow update: if request.auth.uid == userId && 
                      (request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['lastLogin', 'email', 'displayName', 'photoURL']));
      allow read, write: if isAdmin();
      match /preferences/{document=**} {
        allow read: if isOwnUser(userId);
        allow write: if isOwnUser(userId);
      }
      match /activityLog/{document=**} {
        allow read: if isOwnUser(userId) || isAdmin();
        allow write: if isOwnUser(userId) || isAdmin();
      }
    }

    // ============================================================================
    // ARTICLES COLLECTION - Public can read published articles
    // ============================================================================
    match /articles/{articleId} {
      // Public can read published articles
      allow read: if resource.data.status == 'published';
      // Admins and authors can read all articles
      allow read: if isAuthor();
      // Authors and admins can create articles
      allow create: if isAuthor() &&
                       request.resource.data.keys().hasAll(['title', 'slug', 'content', 'excerpt', 'categoryId', 'authorId']) &&
                       request.resource.data.authorId == request.auth.uid;
      // Authors can update their own articles, admins can update any
      allow update: if (isAuthor() && resource.data.authorId == request.auth.uid) || isAdmin();
      // Authors can delete their own articles, admins can delete any
      allow delete: if (isAuthor() && resource.data.authorId == request.auth.uid) || isAdmin();
      // Admins can update article status
      allow update: if isAdmin() && 
                       ('isFeatured' in request.resource.data.diff(resource.data).changedKeys() ||
                        'isSpecial' in request.resource.data.diff(resource.data).changedKeys() ||
                        'isLead' in request.resource.data.diff(resource.data).changedKeys() ||
                        'status' in request.resource.data.diff(resource.data).changedKeys());
    }

    // ============================================================================
    // CATEGORIES COLLECTION - Everyone can read
    // ============================================================================
    match /categories/{categoryId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
      match /subcategories/{subcategoryId} {
        allow read: if true;
        allow create: if isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    // ============================================================================
    // ANALYTICS COLLECTION
    // ============================================================================
    match /analytics/{document=**} {
      allow read: if isAdmin();
      allow write: if request.auth.token.isServerFunction == true;
    }

    // ============================================================================
    // COMMENTS COLLECTION
    // ============================================================================
    match /articles/{articleId}/comments/{commentId} {
      allow read: if exists(/databases/$(database)/documents/articles/$(articleId)) &&
                       get(/databases/$(database)/documents/articles/$(articleId)).data.publishedAt <= request.time.toMillis();
      allow create: if isSignedIn() &&
                       exists(/databases/$(database)/documents/articles/$(articleId)) &&
                       get(/databases/$(database)/documents/articles/$(articleId)).data.publishedAt <= request.time.toMillis() &&
                       request.resource.data.keys().hasAll(['text', 'userId', 'createdAt']) &&
                       request.resource.data.userId == request.auth.uid;
      allow update: if request.auth.uid == resource.data.userId;
      allow delete: if request.auth.uid == resource.data.userId || isAdmin();
    }

    // ============================================================================
    // DEFAULT DENY
    // ============================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
