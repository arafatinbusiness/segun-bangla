rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin';
    }
    
    function isAuthor() {
      return isSignedIn() && 
             exists(/databases/$(database)/documents/users/$(request.auth.uid)) &&
             (get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'author' ||
              get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'admin');
    }
    
    function isOwnUser(uid) {
      return request.auth.uid == uid;
    }

    // ============================================================================
    // USERS COLLECTION - Authentication & Profile Management
    // ============================================================================
    match /users/{userId} {
      
      // Users can create their own profile during registration
      allow create: if request.auth.uid == userId && 
                      request.resource.data.role == 'user' &&
                      request.resource.data.keys().hasAll(['uid', 'role', 'createdAt']);

      // Users can read their own profile
      allow read: if request.auth.uid == userId;

      // Users can update specific fields in their own profile (including lastLogin)
      allow update: if request.auth.uid == userId && 
                      (request.resource.data.diff(resource.data).affectedKeys()
                      .hasOnly(['lastLogin', 'email', 'displayName', 'photoURL']));

      // Admins can do everything
      allow read, write: if isAdmin();
      
      // Subcollection: User preferences/settings
      match /preferences/{document=**} {
        allow read: if isOwnUser(userId);
        allow write: if isOwnUser(userId);
      }
      
      // Subcollection: User activity log
      match /activityLog/{document=**} {
        allow read: if isOwnUser(userId) || isAdmin();
        allow write: if isOwnUser(userId) || isAdmin();
      }
    }

    // ============================================================================
    // ARTICLES COLLECTION - News Content Management
    // ============================================================================
    match /articles/{articleId} {
      
      // Public can read all articles (filtering is done in application code)
      allow read: if true;
      
      // Admins and authors can read all articles (draft, published, scheduled)
      allow read: if isAuthor();
      
      // Authors and admins can create articles
      // categoryId is optional - articles can be published without any category
      allow create: if isAuthor() &&
                       request.resource.data.keys().hasAll(['title', 'slug', 'content', 'excerpt', 'authorId']) &&
                       request.resource.data.authorId == request.auth.uid;

      
      // Authors can update their own articles, admins can update any
      allow update: if (isAuthor() && resource.data.authorId == request.auth.uid) || isAdmin();
      
      // Authors can delete their own articles, admins can delete any
      allow delete: if (isAuthor() && resource.data.authorId == request.auth.uid) || isAdmin();
      
      // Admins can update article status and special ordering
      allow update: if isAdmin() && 
                       request.resource.data.diff(resource.data).affectedKeys()
                       .hasAny(['isFeatured', 'isSpecial', 'isLead', 'isSpecialOrder', 'status']);
    }

    // ============================================================================
    // CATEGORIES COLLECTION - Content Organization
    // ============================================================================
    match /categories/{categoryId} {
      
      // Everyone can read categories
      allow read: if true;
      
      // Only admins can create/update/delete categories
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
      
      // Subcollection: Subcategories
      match /subcategories/{subcategoryId} {
        
        // Everyone can read subcategories
        allow read: if true;
        
        // Only admins can manage subcategories
        allow create: if isAdmin();
        allow update: if isAdmin();
        allow delete: if isAdmin();
      }
    }

    // ============================================================================
    // ADVERTISEMENTS COLLECTION - Ad Management
    // ============================================================================
    match /advertisements/{adId} {
      
      // Everyone can read active advertisements (for displaying on home page)
      allow read: if true;
      
      // Only admins can create/update/delete advertisements
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================================
    // AD SLOTS COLLECTION - Ad Slot Management
    // ============================================================================
    match /adSlots/{slotId} {
      
      // Everyone can read ad slots
      allow read: if true;
      
      // Only admins can create/delete ad slots
      allow create: if isAdmin();
      allow delete: if isAdmin();
    }

    // ============================================================================
    // ANALYTICS COLLECTION
    // ============================================================================
    match /analytics/{document=**} {
      
      // Only admins can read analytics
      allow read: if isAdmin();
      
      // Server-side functions can write analytics
      allow write: if request.auth.token.isServerFunction == true;
    }

    // ============================================================================
    // COMMENTS COLLECTION
    // ============================================================================
    match /articles/{articleId}/comments/{commentId} {
      
      // Everyone can read published comments on published articles
      allow read: if exists(/databases/$(database)/documents/articles/$(articleId)) &&
                       get(/databases/$(database)/documents/articles/$(articleId)).data.publishedAt <= request.time.toMillis();
      
      // Signed-in users can create comments on published articles
      allow create: if isSignedIn() &&
                       exists(/databases/$(database)/documents/articles/$(articleId)) &&
                       get(/databases/$(database)/documents/articles/$(articleId)).data.publishedAt <= request.time.toMillis() &&
                       request.resource.data.keys().hasAll(['text', 'userId', 'createdAt']) &&
                       request.resource.data.userId == request.auth.uid;
      
      // Users can update/delete their own comments
      allow update: if request.auth.uid == resource.data.userId;
      allow delete: if request.auth.uid == resource.data.userId || isAdmin();
    }

    // ============================================================================
    // SETTINGS COLLECTION - App Configuration (excerpt settings, etc.)
    // ============================================================================
    match /settings/{settingId} {
      
      // Everyone can read settings (for homepage display)
      allow read: if true;
      
      // Only admins can write settings
      allow write: if isAdmin();
    }

    // ============================================================================
    // DEFAULT DENY - All other access is denied
    // ============================================================================
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
